{
  "title": "Intelligent IoT API — Observability",
  "uid": "iot-api-dashboard",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests per sekund (alle endpoints)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(flask_http_request_duration_seconds_count[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP request latency p95 (sekunder)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(flask_http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Antal online IoT-enheder",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "iot_devices_online_total",
          "legendFormat": "Online devices"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "Database fejl (total)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(iot_db_errors_total)",
          "legendFormat": "DB fejl"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Device not found (404)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "iot_device_not_found_total",
          "legendFormat": "404 not found"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "HTTP fejlrate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(flask_http_request_total{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status}} {{path}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "MySQL — aktive forbindelser",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "Aktive forbindelser"
        }
      ]
    },
    {
      "id": 8,
      "title": "MySQL — queries per sekund",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries[1m])",
          "legendFormat": "Queries/sek"
        }
      ]
    },
    {
      "id": 9,
      "title": "MySQL — slow queries",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(mysql_global_status_slow_queries[1m])",
          "legendFormat": "Slow queries/sek"
        }
      ]
    }
  ]
}